# ── ChotoVai configuration template ──────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
#
# QUICK START — local models (no cloud API key needed):
#   Ollama:    copy presets\ollama.env .env     then  ollama pull qwen2.5-coder:7b
#   LM Studio: copy presets\lmstudio.env .env   then load model in LM Studio UI
#
# Env var naming:  SLM_AGENT_<SECTION>__<FIELD>=<value>
#   e.g.  SLM_AGENT_MODELS__CODER__BASE_URL=http://localhost:11434/v1
# ─────────────────────────────────────────────────────────────────────────────


# ════════════════════════════════════════════════════════════════════════════
#  MODEL ENDPOINTS  (one block per agent role)
#  Supported backends: vLLM · Ollama · LM Studio · OpenAI · OpenRouter
#  All roles use the OpenAI-compatible /v1/chat/completions API.
# ════════════════════════════════════════════════════════════════════════════

# ── Orchestrator  (Planner · Node Decomposer) ─────────────────────────────────
#SLM_AGENT_MODELS__ORCHESTRATOR__BASE_URL=http://localhost:8000/v1
#SLM_AGENT_MODELS__ORCHESTRATOR__API_KEY=not-required
#SLM_AGENT_MODELS__ORCHESTRATOR__MODEL_NAME=Qwen/Qwen2.5-14B-Instruct
#SLM_AGENT_MODELS__ORCHESTRATOR__TEMPERATURE=0.1
#SLM_AGENT_MODELS__ORCHESTRATOR__MAX_TOKENS=8192
#SLM_AGENT_MODELS__ORCHESTRATOR__TIMEOUT_S=180.0

# ── Coder ─────────────────────────────────────────────────────────────────────
#SLM_AGENT_MODELS__CODER__BASE_URL=http://localhost:8000/v1
#SLM_AGENT_MODELS__CODER__API_KEY=not-required
#SLM_AGENT_MODELS__CODER__MODEL_NAME=Qwen/Qwen2.5-Coder-7B-Instruct
#SLM_AGENT_MODELS__CODER__TEMPERATURE=0.2
#SLM_AGENT_MODELS__CODER__MAX_TOKENS=4096
#SLM_AGENT_MODELS__CODER__TIMEOUT_S=180.0

# ── Tester ────────────────────────────────────────────────────────────────────
#SLM_AGENT_MODELS__TESTER__BASE_URL=http://localhost:8000/v1
#SLM_AGENT_MODELS__TESTER__API_KEY=not-required
#SLM_AGENT_MODELS__TESTER__MODEL_NAME=Qwen/Qwen2.5-Coder-7B-Instruct
#SLM_AGENT_MODELS__TESTER__TEMPERATURE=0.1
#SLM_AGENT_MODELS__TESTER__MAX_TOKENS=4096

# ── Critic  (code reviewer · judge ensemble) ──────────────────────────────────
# Using a different model family reduces "judge drift" (the critic agreeing with
# the coder just because they share weights). Gemma or Phi work well here.
#SLM_AGENT_MODELS__CRITIC__BASE_URL=http://localhost:8000/v1
#SLM_AGENT_MODELS__CRITIC__API_KEY=not-required
#SLM_AGENT_MODELS__CRITIC__MODEL_NAME=google/gemma-2-9b-it
#SLM_AGENT_MODELS__CRITIC__TEMPERATURE=0.0
#SLM_AGENT_MODELS__CRITIC__MAX_TOKENS=2048

# ── Explorer  (codebase traversal) ────────────────────────────────────────────
#SLM_AGENT_MODELS__EXPLORER__BASE_URL=http://localhost:8000/v1
#SLM_AGENT_MODELS__EXPLORER__API_KEY=not-required
#SLM_AGENT_MODELS__EXPLORER__MODEL_NAME=Qwen/Qwen2.5-Coder-7B-Instruct
#SLM_AGENT_MODELS__EXPLORER__TEMPERATURE=0.0
#SLM_AGENT_MODELS__EXPLORER__MAX_TOKENS=4096

# ── Summarizer  (context compression) ────────────────────────────────────────
#SLM_AGENT_MODELS__SUMMARIZER__BASE_URL=http://localhost:8000/v1
#SLM_AGENT_MODELS__SUMMARIZER__API_KEY=not-required
#SLM_AGENT_MODELS__SUMMARIZER__MODEL_NAME=microsoft/Phi-4-mini-instruct
#SLM_AGENT_MODELS__SUMMARIZER__TEMPERATURE=0.1
#SLM_AGENT_MODELS__SUMMARIZER__MAX_TOKENS=1024

# ── Escalation  (frontier fallback) ──────────────────────────────────────────
# Invoked when the Coder↔Critic debate stalls or the judge ensemble disagrees.
# Default: Anthropic Claude via https://api.anthropic.com/v1
# Alternative: OpenRouter  https://openrouter.ai/api/v1  (supports 100+ models)
# Local fallback: point at Ollama/LM Studio to stay fully offline.
#SLM_AGENT_MODELS__ESCALATION__BASE_URL=https://api.anthropic.com/v1
#SLM_AGENT_MODELS__ESCALATION__API_KEY=sk-ant-api03-...
#SLM_AGENT_MODELS__ESCALATION__MODEL_NAME=claude-opus-4-6
#SLM_AGENT_MODELS__ESCALATION__MAX_TOKENS=16384


# ════════════════════════════════════════════════════════════════════════════
#  AGENT LOOP TUNING
#  Defaults are calibrated for frontier models (GPT-4 / Claude Opus class).
#  For local 7–9B SLMs, lower the thresholds to avoid endless debate loops.
# ════════════════════════════════════════════════════════════════════════════

# Critic score (0-10) required to accept Coder output and end the debate.
# Frontier default: 9   |   Local SLM recommended: 7
#SLM_AGENT_AGENT__DEBATE_ACCEPTANCE_THRESHOLD=9

# Maximum Coder↔Critic rounds before deadlock resolution kicks in.
# Frontier default: 5   |   Local SLM recommended: 3
#SLM_AGENT_AGENT__DEBATE_MAX_TURNS=5

# Maximum TAOR iterations per agent call.
# Frontier default: 10  |   Local SLM recommended: 8
#SLM_AGENT_AGENT__MAX_ITERATIONS=10

# Wall-clock timeout per task (seconds). Increase for slow local hardware.
# Frontier default: 300  |   Local SLM recommended: 600
#SLM_AGENT_AGENT__WALL_CLOCK_TIMEOUT_S=300

# Number of parallel candidate generations in Graph of Thoughts.
# Frontier default: 5   |   Local SLM recommended: 2  (saves VRAM)
#SLM_AGENT_AGENT__BEST_OF_N=5

# Confidence below this → escalate to frontier model to break judge disagreement.
#SLM_AGENT_AGENT__DEBATE_ENSEMBLE_CONFIDENCE_THRESHOLD=0.5


# ════════════════════════════════════════════════════════════════════════════
#  MEMORY / INFRASTRUCTURE
#  Start with:  docker-compose -f infra/docker-compose.yml up -d postgres qdrant
# ════════════════════════════════════════════════════════════════════════════

#SLM_AGENT_MEMORY__QDRANT_URL=http://localhost:6333
#SLM_AGENT_MEMORY__POSTGRES_DSN=postgresql+asyncpg://slm:slm@localhost:5432/slm_agent
#SLM_AGENT_MEMORY__EPISODIC_TOP_K=3
#SLM_AGENT_MEMORY__WORKING_MEMORY_MAX_TOKENS=6000


# ════════════════════════════════════════════════════════════════════════════
#  OBSERVABILITY  (Langfuse tracing — optional)
# ════════════════════════════════════════════════════════════════════════════

# Set to False to disable tracing entirely (recommended for local dev).
#SLM_AGENT_OBSERVABILITY__ENABLE_TRACING=True
#SLM_AGENT_OBSERVABILITY__LOG_LEVEL=INFO

# Langfuse cloud:  https://cloud.langfuse.com
# Self-hosted:     set LANGFUSE_HOST to your instance URL
#SLM_AGENT_OBSERVABILITY__LANGFUSE_PUBLIC_KEY=pk-lf-...
#SLM_AGENT_OBSERVABILITY__LANGFUSE_SECRET_KEY=sk-lf-...
#SLM_AGENT_OBSERVABILITY__LANGFUSE_HOST=https://cloud.langfuse.com
