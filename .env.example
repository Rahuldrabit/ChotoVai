# SLM_AGENT configuration template
# Copy this to .env and adjust as necessary

# Models - Base URLs and API Keys
# SLM_AGENT_MODELS__ORCHESTRATOR__BASE_URL=http://localhost:8000/v1
# SLM_AGENT_MODELS__ORCHESTRATOR__API_KEY=not-required

# If you use Ollama locally for development, you can point it here:
# SLM_AGENT_MODELS__ORCHESTRATOR__BASE_URL=http://localhost:11434/v1
# SLM_AGENT_MODELS__CODER__BASE_URL=http://localhost:11434/v1
# SLM_AGENT_MODELS__CODER__MODEL_NAME=qwen2.5-coder:7b

# Escalation endpoint (Anthropic / OpenAI)
# SLM_AGENT_MODELS__ESCALATION__API_KEY=sk-ant-api03-...
# SLM_AGENT_MODELS__ESCALATION__BASE_URL=https://api.anthropic.com/v1

# Memory settings
# SLM_AGENT_MEMORY__QDRANT_URL=http://localhost:6333
# SLM_AGENT_MEMORY__POSTGRES_DSN=postgresql+asyncpg://slm:slm@localhost:5432/slm_agent

# Observability (Langfuse)
# SLM_AGENT_OBSERVABILITY__ENABLE_TRACING=True
# SLM_AGENT_OBSERVABILITY__LANGFUSE_PUBLIC_KEY=pk-lf-...
# SLM_AGENT_OBSERVABILITY__LANGFUSE_SECRET_KEY=sk-lf-...
# SLM_AGENT_OBSERVABILITY__LANGFUSE_HOST=http://localhost:3000
