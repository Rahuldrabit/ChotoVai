# ── ChotoVai — Ollama preset ──────────────────────────────────────────────────
# Copy to .env:   cp presets/ollama.env .env          (Linux/macOS)
#                 copy presets\ollama.env .env         (Windows)
#
# Requires:
#   ollama serve                           # start the Ollama server
#   ollama pull qwen2.5-coder:7b           # the main coding model
#   ollama pull qwen2.5:7b                 # optional — better critic / orchestrator
#
# All roles are wired to localhost:11434 (Ollama's default port).
# The thresholds below are tuned for a 7B SLM — lower than frontier-model defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Orchestrator (Planner, Node Decomposer) ───────────────────────────────────
# Handles goal decomposition and planning. Benefits from a reasoning-focused model.
# If you have qwen2.5:14b pulled, use it here for better plan quality.
SLM_AGENT_MODELS__ORCHESTRATOR__BASE_URL=http://localhost:11434/v1
SLM_AGENT_MODELS__ORCHESTRATOR__API_KEY=ollama
SLM_AGENT_MODELS__ORCHESTRATOR__MODEL_NAME=qwen2.5-coder:7b
SLM_AGENT_MODELS__ORCHESTRATOR__TEMPERATURE=0.1
SLM_AGENT_MODELS__ORCHESTRATOR__MAX_TOKENS=4096
SLM_AGENT_MODELS__ORCHESTRATOR__TIMEOUT_S=180.0

# ── Coder ─────────────────────────────────────────────────────────────────────
SLM_AGENT_MODELS__CODER__BASE_URL=http://localhost:11434/v1
SLM_AGENT_MODELS__CODER__API_KEY=ollama
SLM_AGENT_MODELS__CODER__MODEL_NAME=qwen2.5-coder:7b
SLM_AGENT_MODELS__CODER__TEMPERATURE=0.2
SLM_AGENT_MODELS__CODER__MAX_TOKENS=4096
SLM_AGENT_MODELS__CODER__TIMEOUT_S=180.0

# ── Tester ────────────────────────────────────────────────────────────────────
SLM_AGENT_MODELS__TESTER__BASE_URL=http://localhost:11434/v1
SLM_AGENT_MODELS__TESTER__API_KEY=ollama
SLM_AGENT_MODELS__TESTER__MODEL_NAME=qwen2.5-coder:7b
SLM_AGENT_MODELS__TESTER__TEMPERATURE=0.1
SLM_AGENT_MODELS__TESTER__MAX_TOKENS=4096
SLM_AGENT_MODELS__TESTER__TIMEOUT_S=180.0

# ── Critic (code reviewer / judge) ───────────────────────────────────────────
# Ideally a different model family to reduce judge drift (e.g. qwen2.5:7b for
# its stronger instruction following vs qwen2.5-coder:7b's code focus).
# If you only have qwen2.5-coder, use it here — it works fine for local testing.
SLM_AGENT_MODELS__CRITIC__BASE_URL=http://localhost:11434/v1
SLM_AGENT_MODELS__CRITIC__API_KEY=ollama
SLM_AGENT_MODELS__CRITIC__MODEL_NAME=qwen2.5:7b
SLM_AGENT_MODELS__CRITIC__TEMPERATURE=0.0
SLM_AGENT_MODELS__CRITIC__MAX_TOKENS=2048
SLM_AGENT_MODELS__CRITIC__TIMEOUT_S=120.0

# ── Explorer (codebase traversal & structural analysis) ───────────────────────
SLM_AGENT_MODELS__EXPLORER__BASE_URL=http://localhost:11434/v1
SLM_AGENT_MODELS__EXPLORER__API_KEY=ollama
SLM_AGENT_MODELS__EXPLORER__MODEL_NAME=qwen2.5-coder:7b
SLM_AGENT_MODELS__EXPLORER__TEMPERATURE=0.0
SLM_AGENT_MODELS__EXPLORER__MAX_TOKENS=4096
SLM_AGENT_MODELS__EXPLORER__TIMEOUT_S=120.0

# ── Summarizer (context compression) ─────────────────────────────────────────
# Compresses large code contexts into compact summaries. Any small fast model works.
SLM_AGENT_MODELS__SUMMARIZER__BASE_URL=http://localhost:11434/v1
SLM_AGENT_MODELS__SUMMARIZER__API_KEY=ollama
SLM_AGENT_MODELS__SUMMARIZER__MODEL_NAME=qwen2.5-coder:7b
SLM_AGENT_MODELS__SUMMARIZER__TEMPERATURE=0.1
SLM_AGENT_MODELS__SUMMARIZER__MAX_TOKENS=1024
SLM_AGENT_MODELS__SUMMARIZER__TIMEOUT_S=60.0

# ── Escalation ────────────────────────────────────────────────────────────────
# Used when the debate loop stalls or critics disagree.
# For local-only testing: point at Ollama as a fallback (same model).
# For production: replace with Anthropic / OpenRouter endpoint + real API key.
SLM_AGENT_MODELS__ESCALATION__BASE_URL=http://localhost:11434/v1
SLM_AGENT_MODELS__ESCALATION__API_KEY=ollama
SLM_AGENT_MODELS__ESCALATION__MODEL_NAME=qwen2.5-coder:7b
SLM_AGENT_MODELS__ESCALATION__TEMPERATURE=0.2
SLM_AGENT_MODELS__ESCALATION__MAX_TOKENS=4096
SLM_AGENT_MODELS__ESCALATION__TIMEOUT_S=300.0

# ── Agent loop tuning for local 7B SLMs ──────────────────────────────────────
# Default values are tuned for frontier models (debate threshold 9/10, 5 rounds).
# These lower values prevent the 7B Critic from rejecting everything in an
# endless loop and keep total inference time reasonable on consumer hardware.
SLM_AGENT_AGENT__DEBATE_ACCEPTANCE_THRESHOLD=7
SLM_AGENT_AGENT__DEBATE_MAX_TURNS=3
SLM_AGENT_AGENT__MAX_ITERATIONS=8
SLM_AGENT_AGENT__WALL_CLOCK_TIMEOUT_S=600
SLM_AGENT_AGENT__BEST_OF_N=2

# ── Memory / infrastructure ───────────────────────────────────────────────────
# Start with:  docker-compose -f infra/docker-compose.yml up -d postgres qdrant
SLM_AGENT_MEMORY__QDRANT_URL=http://localhost:6333
SLM_AGENT_MEMORY__POSTGRES_DSN=postgresql+asyncpg://slm:slm@localhost:5432/slm_agent

# ── Observability ─────────────────────────────────────────────────────────────
# Disable Langfuse tracing for local development (no cloud dependency).
SLM_AGENT_OBSERVABILITY__ENABLE_TRACING=False
SLM_AGENT_OBSERVABILITY__LOG_LEVEL=DEBUG
