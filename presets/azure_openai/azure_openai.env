#!/bin/bash
# Azure OpenAI provider environment configuration

AZURE_OPENAI__API_KEY=your-api-key
AZURE_OPENAI__ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI__API_VERSION=2024-02-15-preview

ORCHESTRATOR__BASE_URL=${AZURE_OPENAI__ENDPOINT}v1
ORCHESTRATOR__API_KEY=${AZURE_OPENAI__API_KEY}
ORCHESTRATOR__MODEL_NAME=gpt-4-deployment
ORCHESTRATOR__TEMPERATURE=0.1
ORCHESTRATOR__MAX_TOKENS=8192

CODER__BASE_URL=${AZURE_OPENAI__ENDPOINT}v1
CODER__API_KEY=${AZURE_OPENAI__API_KEY}
CODER__MODEL_NAME=gpt-35-turbo-deployment
CODER__TEMPERATURE=0.2
CODER__MAX_TOKENS=4096

CRITIC__BASE_URL=${AZURE_OPENAI__ENDPOINT}v1
CRITIC__API_KEY=${AZURE_OPENAI__API_KEY}
CRITIC__MODEL_NAME=gpt-4-deployment
CRITIC__TEMPERATURE=0.0
CRITIC__MAX_TOKENS=2048

TESTER__BASE_URL=${AZURE_OPENAI__ENDPOINT}v1
TESTER__API_KEY=${AZURE_OPENAI__API_KEY}
TESTER__MODEL_NAME=gpt-35-turbo-deployment
TESTER__TEMPERATURE=0.1
TESTER__MAX_TOKENS=4096

EXPLORER__BASE_URL=${AZURE_OPENAI__ENDPOINT}v1
EXPLORER__API_KEY=${AZURE_OPENAI__API_KEY}
EXPLORER__MODEL_NAME=gpt-35-turbo-deployment
EXPLORER__TEMPERATURE=0.0
EXPLORER__MAX_TOKENS=2048

SUMMARIZER__BASE_URL=${AZURE_OPENAI__ENDPOINT}v1
SUMMARIZER__API_KEY=${AZURE_OPENAI__API_KEY}
SUMMARIZER__MODEL_NAME=gpt-35-turbo-deployment
SUMMARIZER__TEMPERATURE=0.1
SUMMARIZER__MAX_TOKENS=1024
