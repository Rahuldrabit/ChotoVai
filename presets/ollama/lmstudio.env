# ── ChotoVai — LM Studio preset ───────────────────────────────────────────────
# Copy to .env:   cp presets/lmstudio.env .env          (Linux/macOS)
#                 copy presets\lmstudio.env .env         (Windows)
#
# Requires:
#   LM Studio → Local Server tab → "Start Server"   (default port 1234)
#   Load your model in the LM Studio model picker before sending requests.
#
# Model name format: LM Studio uses the model's display name shown in the UI
# (usually a lowercase slug like "qwen2.5-coder-7b-instruct").
# Check the running model name in LM Studio's server logs or API tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Orchestrator (Planner, Node Decomposer) ───────────────────────────────────
SLM_AGENT_MODELS__ORCHESTRATOR__BASE_URL=http://localhost:1234/v1
SLM_AGENT_MODELS__ORCHESTRATOR__API_KEY=lm-studio
SLM_AGENT_MODELS__ORCHESTRATOR__MODEL_NAME=qwen2.5-coder-7b-instruct
SLM_AGENT_MODELS__ORCHESTRATOR__TEMPERATURE=0.1
SLM_AGENT_MODELS__ORCHESTRATOR__MAX_TOKENS=4096
SLM_AGENT_MODELS__ORCHESTRATOR__TIMEOUT_S=180.0

# ── Coder ─────────────────────────────────────────────────────────────────────
SLM_AGENT_MODELS__CODER__BASE_URL=http://localhost:1234/v1
SLM_AGENT_MODELS__CODER__API_KEY=lm-studio
SLM_AGENT_MODELS__CODER__MODEL_NAME=qwen2.5-coder-7b-instruct
SLM_AGENT_MODELS__CODER__TEMPERATURE=0.2
SLM_AGENT_MODELS__CODER__MAX_TOKENS=4096
SLM_AGENT_MODELS__CODER__TIMEOUT_S=180.0

# ── Tester ────────────────────────────────────────────────────────────────────
SLM_AGENT_MODELS__TESTER__BASE_URL=http://localhost:1234/v1
SLM_AGENT_MODELS__TESTER__API_KEY=lm-studio
SLM_AGENT_MODELS__TESTER__MODEL_NAME=qwen2.5-coder-7b-instruct
SLM_AGENT_MODELS__TESTER__TEMPERATURE=0.1
SLM_AGENT_MODELS__TESTER__MAX_TOKENS=4096
SLM_AGENT_MODELS__TESTER__TIMEOUT_S=180.0

# ── Critic (code reviewer / judge) ───────────────────────────────────────────
# Note: LM Studio only runs one model at a time. All roles will use whichever
# model you have loaded, regardless of what MODEL_NAME says here.
# Load the same qwen2.5-coder model — it handles review well enough locally.
SLM_AGENT_MODELS__CRITIC__BASE_URL=http://localhost:1234/v1
SLM_AGENT_MODELS__CRITIC__API_KEY=lm-studio
SLM_AGENT_MODELS__CRITIC__MODEL_NAME=qwen2.5-coder-7b-instruct
SLM_AGENT_MODELS__CRITIC__TEMPERATURE=0.0
SLM_AGENT_MODELS__CRITIC__MAX_TOKENS=2048
SLM_AGENT_MODELS__CRITIC__TIMEOUT_S=120.0

# ── Explorer ──────────────────────────────────────────────────────────────────
SLM_AGENT_MODELS__EXPLORER__BASE_URL=http://localhost:1234/v1
SLM_AGENT_MODELS__EXPLORER__API_KEY=lm-studio
SLM_AGENT_MODELS__EXPLORER__MODEL_NAME=qwen2.5-coder-7b-instruct
SLM_AGENT_MODELS__EXPLORER__TEMPERATURE=0.0
SLM_AGENT_MODELS__EXPLORER__MAX_TOKENS=4096
SLM_AGENT_MODELS__EXPLORER__TIMEOUT_S=120.0

# ── Summarizer ────────────────────────────────────────────────────────────────
SLM_AGENT_MODELS__SUMMARIZER__BASE_URL=http://localhost:1234/v1
SLM_AGENT_MODELS__SUMMARIZER__API_KEY=lm-studio
SLM_AGENT_MODELS__SUMMARIZER__MODEL_NAME=qwen2.5-coder-7b-instruct
SLM_AGENT_MODELS__SUMMARIZER__TEMPERATURE=0.1
SLM_AGENT_MODELS__SUMMARIZER__MAX_TOKENS=1024
SLM_AGENT_MODELS__SUMMARIZER__TIMEOUT_S=60.0

# ── Escalation ────────────────────────────────────────────────────────────────
# Points at LM Studio as fallback. Replace with a real cloud endpoint + API key
# when you want true frontier-model escalation.
SLM_AGENT_MODELS__ESCALATION__BASE_URL=http://localhost:1234/v1
SLM_AGENT_MODELS__ESCALATION__API_KEY=lm-studio
SLM_AGENT_MODELS__ESCALATION__MODEL_NAME=qwen2.5-coder-7b-instruct
SLM_AGENT_MODELS__ESCALATION__TEMPERATURE=0.2
SLM_AGENT_MODELS__ESCALATION__MAX_TOKENS=4096
SLM_AGENT_MODELS__ESCALATION__TIMEOUT_S=300.0

# ── Agent loop tuning for local 7B SLMs ──────────────────────────────────────
SLM_AGENT_AGENT__DEBATE_ACCEPTANCE_THRESHOLD=7
SLM_AGENT_AGENT__DEBATE_MAX_TURNS=3
SLM_AGENT_AGENT__MAX_ITERATIONS=8
SLM_AGENT_AGENT__WALL_CLOCK_TIMEOUT_S=600
SLM_AGENT_AGENT__BEST_OF_N=2

# ── Memory / infrastructure ───────────────────────────────────────────────────
SLM_AGENT_MEMORY__QDRANT_URL=http://localhost:6333
SLM_AGENT_MEMORY__POSTGRES_DSN=postgresql+asyncpg://slm:slm@localhost:5432/slm_agent

# ── Graph backend (Repo Intel) ────────────────────────────────────────────────
SLM_AGENT_REPO_INTEL__GRAPH_DB_BACKEND=neo4j
SLM_AGENT_REPO_INTEL__NEO4J_URI=bolt://localhost:7687
SLM_AGENT_REPO_INTEL__NEO4J_USER=neo4j
SLM_AGENT_REPO_INTEL__NEO4J_PASSWORD=neo4j

# ── Scoped blackboard (recommended for small local models) ────────────────────
SLM_AGENT_MEMORY__CONTRACTS_ONLY_EXTERNALITY=true

# ── Runtime safety gate for side-effect tools ─────────────────────────────────
SLM_AGENT_APPROVAL_MODE=interactive

# ── Observability ─────────────────────────────────────────────────────────────
SLM_AGENT_OBSERVABILITY__ENABLE_TRACING=False
SLM_AGENT_OBSERVABILITY__LOG_LEVEL=DEBUG
