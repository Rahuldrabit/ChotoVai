#!/bin/bash
# OpenRouter provider environment configuration

OPENROUTER__API_KEY=sk-or-YOUR_API_KEY_HERE

ORCHESTRATOR__BASE_URL=https://openrouter.ai/api/v1
ORCHESTRATOR__API_KEY=${OPENROUTER__API_KEY}
ORCHESTRATOR__MODEL_NAME=openai/gpt-4-turbo-preview
ORCHESTRATOR__TEMPERATURE=0.1
ORCHESTRATOR__MAX_TOKENS=8192

CODER__BASE_URL=https://openrouter.ai/api/v1
CODER__API_KEY=${OPENROUTER__API_KEY}
CODER__MODEL_NAME=openai/gpt-3.5-turbo
CODER__TEMPERATURE=0.2
CODER__MAX_TOKENS=4096

CRITIC__BASE_URL=https://openrouter.ai/api/v1
CRITIC__API_KEY=${OPENROUTER__API_KEY}
CRITIC__MODEL_NAME=openai/gpt-3.5-turbo
CRITIC__TEMPERATURE=0.0
CRITIC__MAX_TOKENS=2048

TESTER__BASE_URL=https://openrouter.ai/api/v1
TESTER__API_KEY=${OPENROUTER__API_KEY}
TESTER__MODEL_NAME=openai/gpt-3.5-turbo
TESTER__TEMPERATURE=0.1
TESTER__MAX_TOKENS=4096

EXPLORER__BASE_URL=https://openrouter.ai/api/v1
EXPLORER__API_KEY=${OPENROUTER__API_KEY}
EXPLORER__MODEL_NAME=openai/gpt-3.5-turbo
EXPLORER__TEMPERATURE=0.0
EXPLORER__MAX_TOKENS=2048

SUMMARIZER__BASE_URL=https://openrouter.ai/api/v1
SUMMARIZER__API_KEY=${OPENROUTER__API_KEY}
SUMMARIZER__MODEL_NAME=openai/gpt-3.5-turbo
SUMMARIZER__TEMPERATURE=0.1
SUMMARIZER__MAX_TOKENS=1024
